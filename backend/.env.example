APP_NAME="Review Generator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FRONTEND_URL=http://localhost:5173

# Optional: OpenAI API Key for real AI review generation
# Leave empty to use built-in Hinglish template engine
OPENAI_API_KEY=
