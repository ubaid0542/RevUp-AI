APP_NAME="Review Generator"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

ADMIN_PASSWORD=change_this_password

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/path/to/database.sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FRONTEND_URL=http://localhost:5173

# API Keys (keep secret, never commit real values)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
